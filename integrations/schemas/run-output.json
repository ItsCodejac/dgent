{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jent.dev/schemas/run-output.json",
  "title": "jent run --json output",
  "description": "JSON output produced by `jent run --json <file>`. Exit codes: 0 = clean or fixes applied, 1 = flags found.",
  "type": "object",
  "required": ["file", "phase", "clean", "fixes", "flags"],
  "additionalProperties": false,
  "properties": {
    "file": {
      "type": ["string", "null"],
      "description": "Path to the file that was processed, or null when reading from stdin."
    },
    "phase": {
      "type": "string",
      "enum": ["commit-msg", "pre-commit", "both"],
      "description": "Which rule phase was executed."
    },
    "clean": {
      "type": "boolean",
      "description": "True when no fixes were applied and no flags were raised."
    },
    "fixes": {
      "type": "array",
      "description": "Rules that modified the content.",
      "items": {
        "type": "object",
        "required": ["rule"],
        "additionalProperties": false,
        "properties": {
          "rule": {
            "type": "string",
            "description": "Name of the rule that applied a fix."
          }
        }
      }
    },
    "flags": {
      "type": "array",
      "description": "Warnings raised by flag rules.",
      "items": {
        "type": "object",
        "required": ["rule", "line", "message"],
        "additionalProperties": false,
        "properties": {
          "rule": {
            "type": "string",
            "description": "Name of the rule that raised the flag."
          },
          "line": {
            "type": "number",
            "description": "1-based line number where the issue was found."
          },
          "message": {
            "type": "string",
            "description": "Human-readable description of the issue."
          },
          "suggestion": {
            "type": "string",
            "description": "Optional suggested replacement or action."
          }
        }
      }
    },
    "output": {
      "type": "string",
      "description": "Cleaned file content. Only present when fixes were applied (content changed)."
    }
  }
}
