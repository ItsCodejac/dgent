{
  "name": "dgent",
  "version": "0.1.0",
  "description": "Strip AI tells from agent output — commit trailers, noise comments, emoji, AI vocabulary, and more",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "dgent": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "src/ai/skill.md",
    "test/fixtures/",
    "llms.txt"
