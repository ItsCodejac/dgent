{
  "name": "dgent",
  "version": "0.1.0",
  "description": "De-agent your code — clean AI tells from commits and code automatically via git hooks",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "dgent": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "src/ai/skill.md",
    "test/fixtures/",
    "integrations/",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "preuninstall": "dgent uninstall 2>/dev/null || true"
  },
  "publishConfig": {
    "provenance": true
  },
  "os": [
    "darwin",
    "linux"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "git",
    "hooks",
    "ai",
    "agent",
    "cli",
    "commit",
    "code-quality",
    "developer-tools",
    "linter",
    "copilot",
    "claude",
    "cursor",
    "codex",
    "lint",
    "pre-commit",
    "commit-msg",
    "code-review",
    "clean-code",
    "ai-detection",
    "typescript",
    "javascript",
    "python"
  ],
  "author": "Cojac <cojacproduction@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cojac/dgent"
  },
  "homepage": "https://github.com/cojac/dgent",
  "bugs": {
    "url": "https://github.com/cojac/dgent/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@inkjs/ui": "^2.0.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "react": "^19.2.4"
  }
}
