    "code-quality",
    "developer-tools",
    "linter",
    "copilot",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cojac/dgent"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "commander": "^14.0.3"
  }
}
